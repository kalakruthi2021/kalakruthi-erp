generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth & Users ──

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  fullName      String    @map("full_name")
  phone         String?
  avatarUrl     String?   @map("avatar_url")
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  auditLogs        AuditLog[]
  paymentsReceived Payment[] @relation("ReceivedBy")

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

// ── Contacts (Heart of the System) ──

model Contact {
  id            String    @id @default(uuid()) @db.Uuid
  firstName     String    @map("first_name")
  lastName      String?   @map("last_name")
  displayName   String    @map("display_name")
  phone         String    @unique
  altPhone      String?   @map("alt_phone")
  email         String?
  companyName   String?   @map("company_name")
  address       String?
  city          String?
  state         String?
  pincode       String?
  source        ContactSource @default(OTHER)
  referredById  String?   @map("referred_by_id") @db.Uuid
  notes         String?
  isActive      Boolean   @default(true) @map("is_active")
  metadata      Json?     @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  roles              ContactRole[]
  referredBy         Contact?   @relation("Referrals", fields: [referredById], references: [id])
  referrals          Contact[]  @relation("Referrals")
  projectsAsCustomer Project[]  @relation("CustomerProjects")
  projectsAsPartner  Project[]  @relation("PartnerProjects")
  crewAssignments    ProjectCrew[]
  payments           Payment[]
  ledgerEntries      LedgerEntry[]

  @@index([phone])
  @@index([displayName])
  @@index([city, state])
  @@map("contacts")
}

enum ContactSource {
  WALK_IN
  REFERRAL
  ONLINE
  PARTNER
  SOCIAL_MEDIA
  REPEAT
  OTHER
}

model ContactRole {
  id          String    @id @default(uuid()) @db.Uuid
  contactId   String    @map("contact_id") @db.Uuid
  role        RoleType
  designation String?
  dailyRate   Decimal?  @map("daily_rate") @db.Decimal(10, 2)
  notes       String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, role])
  @@map("contact_roles")
}

enum RoleType {
  CUSTOMER
  VENDOR
  EMPLOYEE
  FREELANCER
  PARTNER_STUDIO
  REFERRER
}

// ── Services ──

model Service {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  channel       ServiceChannel
  category      String?
  basePrice     Decimal?  @map("base_price") @db.Decimal(10, 2)
  unit          String?
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  projectServices ProjectService[]

  @@map("services")
}

enum ServiceChannel {
  B2C
  B2B
  BOTH
}

// ── Event Types ──

model EventType {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  category    String
  icon        String?
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")

  projectEvents ProjectEvent[]

  @@map("event_types")
}

// ── Projects ──

model Project {
  id              String    @id @default(uuid()) @db.Uuid
  projectNumber   String    @unique @map("project_number")
  customerId      String    @map("customer_id") @db.Uuid
  partnerId       String?   @map("partner_id") @db.Uuid
  projectType     ProjectType @default(DIRECT_BOOKING) @map("project_type")
  title           String?
  status          ProjectStatus @default(INQUIRY)
  location        String?
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(10, 2)
  netAmount       Decimal   @default(0) @map("net_amount") @db.Decimal(12, 2)
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceAmount   Decimal   @default(0) @map("balance_amount") @db.Decimal(12, 2)
  isUrgent        Boolean   @default(false) @map("is_urgent")
  notes           String?
  metadata        Json?     @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  customer        Contact   @relation("CustomerProjects", fields: [customerId], references: [id])
  partner         Contact?  @relation("PartnerProjects", fields: [partnerId], references: [id])
  events          ProjectEvent[]
  services        ProjectService[]
  crew            ProjectCrew[]
  payments        Payment[]
  productionTasks ProductionTask[]
  invoices        Invoice[]
  workLogs        WorkLog[]

  @@index([customerId])
  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("projects")
}

enum ProjectType {
  DIRECT_BOOKING
  PARTNER_REFERRAL
  OUTSOURCED_WORK
  EDITING_ONLY
  SAVE_THE_DATE
}

enum ProjectStatus {
  INQUIRY
  QUOTATION_SENT
  CONFIRMED
  SCHEDULED
  IN_PROGRESS
  POST_PRODUCTION
  DELIVERED
  COMPLETED
  CANCELLED
  ARCHIVED
}

// ── Project Sub-Events (Multi-Day Support) ──

model ProjectEvent {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  eventTypeId   String    @map("event_type_id") @db.Uuid
  eventDate     DateTime  @map("event_date") @db.Date
  startTime     String?   @map("start_time")
  endTime       String?   @map("end_time")
  venue         String?
  notes         String?
  sortOrder     Int       @default(0) @map("sort_order")

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventType     EventType @relation(fields: [eventTypeId], references: [id])

  @@index([eventDate])
  @@map("project_events")
}

// ── Project Services (Line Items) ──

model ProjectService {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  serviceId   String    @map("service_id") @db.Uuid
  quantity    Int       @default(1)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(10, 2)
  notes       String?

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id])

  @@map("project_services")
}

// ── Project Crew (Staff Assignments) ──

model ProjectCrew {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  contactId   String    @map("contact_id") @db.Uuid
  role        String
  dailyRate   Decimal?  @map("daily_rate") @db.Decimal(10, 2)
  days        Int       @default(1)
  totalCost   Decimal?  @map("total_cost") @db.Decimal(10, 2)
  status      CrewStatus @default(ASSIGNED)
  notes       String?

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id])

  @@unique([projectId, contactId])
  @@map("project_crew")
}

enum CrewStatus {
  ASSIGNED
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ── Payments ──

model Payment {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  contactId     String    @map("contact_id") @db.Uuid
  amount        Decimal   @db.Decimal(10, 2)
  paymentDate   DateTime  @map("payment_date") @db.Date
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  paymentType   PaymentType   @default(ADVANCE) @map("payment_type")
  direction     PaymentDirection @default(INCOMING)
  referenceNo   String?   @map("reference_no")
  notes         String?
  receivedById  String?   @map("received_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")

  project       Project   @relation(fields: [projectId], references: [id])
  contact       Contact   @relation(fields: [contactId], references: [id])
  receivedBy    User?     @relation("ReceivedBy", fields: [receivedById], references: [id])

  @@index([projectId])
  @@index([contactId])
  @@index([paymentDate])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
  OTHER
}

enum PaymentType {
  ADVANCE
  INSTALLMENT
  FINAL_SETTLEMENT
  REFUND
  PARTIAL
  FULL
}

enum PaymentDirection {
  INCOMING
  OUTGOING
}

// ── Ledger (General Accounting) ──

model LedgerEntry {
  id          String    @id @default(uuid()) @db.Uuid
  entryType   LedgerType @map("entry_type")
  category    String
  contactId   String?   @map("contact_id") @db.Uuid
  personName  String?   @map("person_name")
  purpose     String
  amount      Decimal   @db.Decimal(10, 2)
  entryDate   DateTime  @map("entry_date") @db.Date
  status      LedgerStatus @default(PENDING)
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  contact     Contact?  @relation(fields: [contactId], references: [id])

  @@index([entryDate])
  @@index([category])
  @@map("ledger_entries")
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum LedgerStatus {
  PENDING
  SETTLED
}

// ── Production Tasks ──

model ProductionTask {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  taskType    String    @map("task_type")
  title       String
  status      TaskStatus @default(PENDING)
  assignedTo  String?   @map("assigned_to")
  dueDate     DateTime? @map("due_date") @db.Date
  completedAt DateTime? @map("completed_at")
  notes       String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("production_tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED
  BLOCKED
}

// ── Work Logs ──

model WorkLog {
  id          String    @id @default(uuid()) @db.Uuid
  logType     WorkLogType @default(PROFESSIONAL) @map("log_type")
  logDate     DateTime  @map("log_date") @db.Date
  content     String
  isCompleted Boolean   @default(false) @map("is_completed")
  projectId   String?   @map("project_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  project     Project?  @relation(fields: [projectId], references: [id])

  @@index([logDate])
  @@map("work_logs")
}

enum WorkLogType {
  PERSONAL
  PROFESSIONAL
}

// ── Invoices ──

model Invoice {
  id            String    @id @default(uuid()) @db.Uuid
  invoiceNumber String    @unique @map("invoice_number")
  projectId     String    @map("project_id") @db.Uuid
  invoiceType   InvoiceType @default(TAX_INVOICE) @map("invoice_type")
  subtotal      Decimal   @db.Decimal(12, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal   @map("total_amount") @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime? @map("issued_at")
  dueDate       DateTime? @map("due_date") @db.Date
  pdfUrl        String?   @map("pdf_url")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  project       Project   @relation(fields: [projectId], references: [id])

  @@map("invoices")
}

enum InvoiceType {
  QUOTATION
  TAX_INVOICE
  RECEIPT
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

// ── Media Files ──

model MediaFile {
  id          String    @id @default(uuid()) @db.Uuid
  fileName    String    @map("file_name")
  fileUrl     String    @map("file_url")
  fileType    String    @map("file_type")
  fileSize    BigInt    @map("file_size")
  projectId   String?   @map("project_id") @db.Uuid
  uploadedBy  String?   @map("uploaded_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("media_files")
}

// ── Audit Log ──

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  action      AuditAction
  entityType  String    @map("entity_type")
  entityId    String    @map("entity_id") @db.Uuid
  oldValues   Json?     @map("old_values")
  newValues   Json?     @map("new_values")
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}
